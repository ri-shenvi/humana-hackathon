# Copy to .env and fill in.  .env is gitignored -- never commit credentials.
# Verify any setup with:  python -m caregap_compass.scripts.doctor --model

# ===========================================================================
# AUTH -- pick ONE of the two blocks below
# ===========================================================================

# --- A) Vertex AI + ADC  <-- USE THIS FOR THE HUMANA PROJECT ---------------
# The enterprise path. No secret goes in this file at all: Application Default
# Credentials authenticate BOTH Gemini and BigQuery from one login, so there is
# nothing to leak into a Humana-connected repo.
#
#   gcloud auth application-default login
#   # or, on a GCP VM / Cloud Shell, attach a service account with:
#   #   roles/aiplatform.user        (Gemini via Vertex)
#   #   roles/bigquery.dataViewer    (read humana_hackathon)
#   #   roles/bigquery.jobUser       (run queries)
#
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# --- B) AI Studio API key -- LOCAL SCRATCH ONLY ----------------------------
# Bills a personal account, not the hackathon project, and enterprise policy
# often blocks it. Do not use this on the Humana environment. If you set it,
# comment out GOOGLE_GENAI_USE_VERTEXAI above -- Vertex takes precedence and the
# key is silently ignored.
#
# GOOGLE_API_KEY=

# ===========================================================================
# MODEL
# ===========================================================================
# On Vertex an alias may not resolve; if the doctor reports the model is
# rejected, pin a version (e.g. gemini-2.5-flash).
CARE_GAP_MODEL=gemini-flash-latest

# ===========================================================================
# DATA BACKEND
# ===========================================================================
# auto     -> BigQuery when reachable, else local CSVs (default; good for dev)
# bigquery -> require BigQuery, fail loudly if unreachable (use for the demo,
#             so a silent CSV fallback can never be mistaken for a live query)
# csv      -> always read caregap_compass/data/runtime/extracted/structured
DATA_BACKEND=auto

BQ_DATASET=humana_hackathon
BQ_LOCATION=US

# Load the dataset first (needs the bq CLI -- easiest in Google Cloud Shell):
#   cd caregap_compass/data/runtime/reference
#   chmod +x import-bq.sh && ./import-bq.sh ../extracted/structured
# Then confirm it took:
#   python -m caregap_compass.scripts.doctor

# ===========================================================================
# DEMO CLOCK
# ===========================================================================
# The synthetic data was generated around 2026-06-10: appointment slots run
# 2026-06-11..2026-07-10 and gap due dates fan out from mid-2026. On the real
# wall clock every slot is expired and days-to-close goes negative, which breaks
# both scoring and booking. Do not change this without re-running the doctor.
DEMO_TODAY=2026-06-10

HERO_MEMBER_ID=MBR00030

# ===========================================================================
# TUNING
# ===========================================================================
BQ_CACHE_CAPACITY=128
BQ_CACHE_TTL=300
URGENCY_HORIZON_DAYS=270
NEUTRAL_CHANNEL_PRIOR=0.5
